# Copy this file to .env and fill in the values you want to override.
# Both `uv run uvicorn ...` (via python-dotenv) and `docker compose up`
# (via the env_file directive) will load it automatically.

# --- Storage / runtime ---
# DATA_DIR=./data
# DATABASE_PATH=./data/stock_watcher.sqlite3
# TZ=UTC

# --- Scheduler / retention ---
# CHECK_LOOP_INTERVAL_SECONDS=15
# EVENT_RETENTION_LIMIT=1000
# ATTEMPT_RETENTION_LIMIT=5000

# --- Notifications ---
# Three delivery channels, all configured in the Settings page and combinable:
#   - Web Push (default): notifications to installed PWAs. The VAPID keypair is
#     generated and stored under DATA_DIR (vapid_private.pem) on first use;
#     only the contact below is configurable.
#   - Webhook: one JSON POST with Discord / Slack / generic (Home Assistant,
#     Zapier, n8n, ...) presets.
#   - ntfy: push via an ntfy server/topic.

# VAPID `sub` claim for Web Push — a mailto:/https: contact some push services
# require. Change it to your own address.
# WEBPUSH_CONTACT=mailto:admin@example.com

# --- ntfy notifications ---
# NTFY_SERVER=https://ntfy.sh
# NTFY_TOPIC=
# Delivery is retried on transient failures (timeouts, connection errors, 429,
# 5xx) with exponential backoff. NTFY_MAX_ATTEMPTS is the total number of tries
# (1 disables retries); NTFY_RETRY_BACKOFF_SECONDS is the base delay, doubled
# each retry and capped at 5s. Permanent rejections (401/403/404) fail fast.
# NTFY_MAX_ATTEMPTS=3
# NTFY_RETRY_BACKOFF_SECONDS=0.5

# --- LLM (AI rule helper) ---
# Bearer token sent to the OpenAI-compatible Chat Completions endpoint
# configured in Settings (base URL + model + extra params). Leave blank
# to disable the "Configure rule with AI" helper in the editor.
LLM_API_KEY=
# Max characters of cleaned page HTML sent to the LLM per suggestion.
# Default 200000 fits comfortably in modern models (Claude 4.x, GPT-4o);
# lower it if you point the helper at a small-context local model.
# LLM_HTML_CHAR_LIMIT=200000
