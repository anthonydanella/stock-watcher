# Copy this file to .env and fill in the values you want to override.
# Both `uv run uvicorn ...` (via python-dotenv) and `docker compose up`
# (via the env_file directive) will load it automatically.

# --- Storage / runtime ---
# DATA_DIR=./data
# DATABASE_PATH=./data/stock_watcher.sqlite3
# TZ=UTC

# --- Scheduler / retention ---
# CHECK_LOOP_INTERVAL_SECONDS=15
# EVENT_RETENTION_LIMIT=1000
# ATTEMPT_RETENTION_LIMIT=5000

# --- ntfy notifications ---
# NTFY_SERVER=https://ntfy.sh
# NTFY_TOPIC=

# --- LLM (AI rule helper) ---
# Bearer token sent to the OpenAI-compatible Chat Completions endpoint
# configured in Settings (base URL + model + extra params). Leave blank
# to disable the "Configure rule with AI" helper in the editor.
LLM_API_KEY=
# Max characters of cleaned page HTML sent to the LLM per suggestion.
# Default 200000 fits comfortably in modern models (Claude 4.x, GPT-4o);
# lower it if you point the helper at a small-context local model.
# LLM_HTML_CHAR_LIMIT=200000
